{
  "name": "savage-frameworks",
  "version": "0.1.0-alpha",
  "description": "A lightweight, open-source HTML, CSS, and JavaScript framework for building reactive websites",
  "main": "dist/savage.js",
  "module": "dist/savage.esm.js",
  "unpkg": "dist/savage.min.js",
  "jsdelivr": "dist/savage.min.js",
  "types": "dist/savage.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "release": "npm run build && npm test && npm version"
  },
  "keywords": [
    "framework",
    "reactive",
    "javascript",
    "html",
    "css",
    "dom",
    "lightweight",
    "standards-compliant"
  ],
  "author": "Savage Nights Collective",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/savagenights/savage_frameworks.git"
  },
  "bugs": {
    "url": "https://github.com/savagenights/savage_frameworks/issues"
  },
  "homepage": "https://github.com/savagenights/savage_frameworks#readme",
  "browserslist": [
    "defaults",
    "not IE 11"
  ],
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "rollup": "^4.0.0"
  }
}
