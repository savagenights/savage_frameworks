# 🦁 Savage Frameworks - Docker Ignore
#
# Files and directories to exclude from Docker build context
# Repository: https://github.com/savagenights/savage_frameworks.git

# Git
.git
.gitignore
.gitattributes

# Node.js / NPM
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Development files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Testing
tests
coverage
.nyc_output
*.test.js
*.spec.js

# Build artifacts (we'll build fresh in container if needed)
dist
*.log

# Documentation that shouldn't be in image
CONTRIBUTING.md
docs/

# CI/CD
.github
.gitlab-ci.yml
.travis.yml

# Docker files themselves (not needed in context)
Dockerfile
docker-compose.yml
.dockerignore

# Temporary files
tmp
temp
*.tmp
